generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ApiKey {
  id        String   @id @default(cuid())
  provider  String
  name      String
  key       String
  baseUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id           String    @id @default(cuid())
  title        String    @default("New Chat")
  provider     String
  model        String
  systemPrompt String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  model          String?
  provider       String?
  tokensIn       Int          @default(0)
  tokensOut      Int          @default(0)
  latencyMs      Int          @default(0)
  costUsd        Float        @default(0)
  sentiment      String?
  language       String?
  imageUrls      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id        String   @id @default(cuid())
  provider  String
  model     String
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  costUsd   Float    @default(0)
  latencyMs Int      @default(0)
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())
}

model MemoryNote {
  id        String   @id @default(cuid())
  key       String
  value     String
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeDoc {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("text")
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPreferences {
  id              String   @id @default(cuid())
  language        String   @default("en")
  responseTone    String   @default("balanced")
  enableMemory    Boolean  @default(true)
  enableSentiment Boolean  @default(true)
  monthlyBudget   Float    @default(0)
  budgetAlert     Boolean  @default(false)
  dataRetention   String   @default("forever")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
